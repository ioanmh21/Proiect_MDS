# ─── Transcription Service Config ───────────────
# Copiază în transcription-service/.env și ajustează

# Modelul Whisper: tiny | base | small | medium | large
# (base = echilibru bun calitate/viteză)
WHISPER_MODEL=base

# Durată maximă video în secunde (3600 = 1 oră)
MAX_DURATION_SEC=3600

# Dimensiune maximă fișier upload în MB
MAX_FILE_SIZE_MB=500

# Origini CORS permise (separate prin virgulă)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Număr de thread-uri pentru executor (Whisper + yt-dlp)
# Recomand 2 pe CPU cu 4+ core-uri
EXECUTOR_WORKERS=2
